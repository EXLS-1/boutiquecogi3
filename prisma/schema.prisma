// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// MODÈLES D'AUTHENTIFICATION (NextAuth)
// ==========================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

// ==========================================
// MODÈLES E-COMMERCE (Boutique COGI)
// ==========================================

model Product {
  id          String           @id @default(cuid())
  name        String
  description String           @db.Text
  price       Decimal          @db.Decimal(10, 2)
  images      String[]
  category    String           @db.VarChar(50)
  stock       Int              @default(0)
  isFeatured  Boolean          @default(false)
  isArchived  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orderItems  OrderItem[]

  @@index([category, isArchived])
  @@index([isFeatured, isArchived])
  @@index([createdAt, isArchived])
}

model Order {
  id              String           @id @default(cuid())
  userId          String?
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  status          OrderStatus      @default(PENDING)
  totalAmount     Int              // Stocké en centimes
  stripeSessionId String?          @unique
  isPaid          Boolean          @default(false)
  phone           String           @default("")
  address         String           @default("")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  orderItems      OrderItem[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([isPaid, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int     @default(1)
  price     Int     // Prix en centimes au moment de l'achat (historisation)

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}